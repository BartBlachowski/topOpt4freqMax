{
  "meta": {
    "name": "Simply supported beam — revision experiments",
    "notes": "8x1 m, pin supports at mid-height nodes, VF=0.5. Emin=1e-9 per Section 4.1. OC optimizer."
  },
  "domain": {
    "shape": "rectangular",
    "size": { "length": 8.0, "height": 1.0 },
    "thickness": 1.0,
    "mesh": { "nelx": 400, "nely": 50 },
    "load_cases": [
      {
        "name": "mode1_semi_harmonic",
        "factor": 1.0,
        "loads": [
          { "type": "semi_harmonic", "mode": 1, "factor": 1.0 }
        ]
      }
    ]
  },
  "material": {
    "model": "plane_stress_isotropic",
    "E": 1.0e7,
    "nu": 0.3,
    "rho": 1.0
  },
  "void_material": {
    "E_min_ratio": 1e-9,
    "rho_min": 1e-9
  },
  "bc": {
    "supports": [
      { "type": "closest_point", "location": [0.0, 0.5], "dofs": ["ux", "uy"] },
      { "type": "closest_point", "location": [8.0, 0.5], "dofs": ["ux", "uy"] }
    ]
  },
  "optimization": {
    "approach": "ourApproach",
    "optimizer": "OC",
    "objective": "compliance",
    "interpolation": "SIMP",
    "volume_fraction": 0.5,
    "penalization": 3.0,
    "semi_harmonic_baseline": "initial",
    "semi_harmonic_rho_source": "x",
    "harmonic_normalize": false,
    "filter": {
      "type": "sensitivity",
      "heaviside": false,
      "radius": 2.0,
      "radius_units": "element",
      "boundary_condition": "symmetric"
    },
    "move_limit": 0.2,
    "max_iters": 2000,
    "convergence_tol": 1e-3
  },
  "postprocessing": {
    "visualize_live": false,
    "visualize_quality": "regular",
    "visualize_modes":          { "enabled": false, "count": 1 },
    "visualize_topology_modes": { "enabled": false, "count": 1 },
    "write_correlation_table":  false,
    "save_snapshot_image":      false,
    "save_final_image":         false,
    "save_frequency_iterations": false
  }
}
